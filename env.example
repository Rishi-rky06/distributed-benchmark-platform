# ══════════════════════════════════════════════════════════════════════════════
#  Distributed Benchmark Platform — Environment Variables
#  Copy this file to `.env` and fill in your values before running.
#  NEVER commit `.env` to version control.
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_SECRET_KEY=change-me-to-a-32-char-random-string


# ── Backend Server ─────────────────────────────────────────────────────────────
BACKEND_PORT=8080
BACKEND_LOG_LEVEL=debug       # debug | info | warn | error
BACKEND_READ_TIMEOUT=30s
BACKEND_WRITE_TIMEOUT=30s
BACKEND_MAX_UPLOAD_MB=256     # Max size for contestant submission uploads


# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost        # Overridden to "postgres" inside Docker
POSTGRES_HOST_PORT=5432        # Host-side port mapping
POSTGRES_DB=benchmark
POSTGRES_USER=bench_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_SSLMODE=disable       # Use "require" in production
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5m


# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost           # Overridden to "redis" inside Docker
REDIS_HOST_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0
REDIS_MAXMEMORY=256mb
# Channel/key prefixes
REDIS_TELEMETRY_CHANNEL=telemetry:stream
REDIS_LEADERBOARD_KEY=leaderboard:global


# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_BASE_URL=ws://localhost:8080


# ── Sandbox / Container Isolation ──────────────────────────────────────────────
SANDBOX_CPU_LIMIT=1.0          # Number of CPUs allocated per submission
SANDBOX_MEMORY_LIMIT=512m      # Hard memory cap per sandboxed container
SANDBOX_TIMEOUT_SECONDS=300    # Max wall-clock time for a benchmark run
SANDBOX_NETWORK_MODE=isolated  # isolated | host (host for debugging only)
SUBMISSIONS_DIR=./submissions  # Host path for staged submission artefacts


# ── Load Generator (Bot Fleet) ─────────────────────────────────────────────────
BOT_FLEET_MIN_WORKERS=100
BOT_FLEET_MAX_WORKERS=5000
BOT_RAMP_DURATION=30s          # Time to ramp from min to max workers
BOT_PROTOCOL=websocket         # websocket | rest | fix
BOT_ORDER_RATE_PER_WORKER=50   # Target orders/sec per bot worker


# ── Telemetry & Scoring ────────────────────────────────────────────────────────
TELEMETRY_FLUSH_INTERVAL=500ms
BENCHMARK_DURATION=60s         # Duration of the main stress window
SCORE_WEIGHT_LATENCY=0.30
SCORE_WEIGHT_THROUGHPUT=0.30
SCORE_WEIGHT_CORRECTNESS=0.30
SCORE_WEIGHT_STABILITY=0.10


# ── JWT Auth (for participant dashboard) ──────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY=24h
